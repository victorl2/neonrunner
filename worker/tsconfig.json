{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "./node_modules/@cloudflare/vitest-pool-workers/types/cloudflare-test"
    ]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
